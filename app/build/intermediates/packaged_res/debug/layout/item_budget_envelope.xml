<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingVertical="8dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <TextView android:id="@+id/tv_envelope_name" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textAppearance="?attr/textAppearanceBodyMedium" android:textColor="?attr/colorOnSurface" android:textStyle="bold" />
        <TextView android:id="@+id/tv_envelope_progress" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textAppearance="?attr/textAppearanceBodySmall" android:textColor="?attr/colorOnSurfaceVariant"/>
    </LinearLayout>

    <com.google.android.material.progressindicator.LinearProgressIndicator android:id="@+id/progress_envelope" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" app:trackThickness="8dp" app:trackCornerRadius="4dp" app:trackColor="?attr/colorSurfaceVariant"/>
</LinearLayout>
